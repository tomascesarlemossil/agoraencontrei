# ─────────────────────────────────────────────────────────────────────────────
# .env para o script de upload do backup para o Supabase
# Renomeie este arquivo para .env na pasta apps/api
# ─────────────────────────────────────────────────────────────────────────────

# URL do projeto Supabase
SUPABASE_URL=https://oenbzvxcsgyzqjtlovdq.supabase.co

# Chave service_role (com acesso total ao Storage e banco)
# Encontre em: Supabase → Settings → API Keys → Legacy → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.COLE_AQUI_A_CHAVE_COMPLETA

# Banco de dados PostgreSQL (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require

# Caminho raiz do backup no seu computador Windows
# Use a pasta que contém as subpastas: ARQUIVO MORTO, FINANCEIRO, LOCAÇÃO, etc.
BACKUP_PATH=Y:\a lemos 2024
