# ─────────────────────────────────────────────
# AgoraEncontrei API — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3100
LOG_LEVEL=info
APP_URL=http://localhost:3100
WEB_URL=http://localhost:3000

# Database (Neon PostgreSQL)
# Get at: https://neon.tech → Create Project → Connection String
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=your_64_char_secret_here_replace_me_now
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
COOKIE_SECRET=your_64_char_cookie_secret_here_replace_me

# OAuth — Google (optional)
# Get at: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# AWS S3 (Fase 3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=agoraencontrei-media

# Redis — Upstash (Fase 3)
# Get at: https://console.upstash.com → Create Database
REDIS_URL=
REDIS_TOKEN=

# Email — SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@agoraencontrei.com.br
