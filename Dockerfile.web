FROM node:22-slim AS base

RUN apt-get update -y && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@10.0.0 --activate

WORKDIR /app

# Copy workspace manifests. Every workspace package.json has to be in
# place before `pnpm install` so the `workspace:*` symlinks get created —
# apps/web depends on @agoraencontrei/tomas-knowledge and imports it from
# the app/api/chat/stream route.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/database/package.json ./packages/database/
COPY packages/tomas-knowledge/package.json ./packages/tomas-knowledge/
COPY apps/web/package.json ./apps/web/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source (include every workspace package the web app transpiles).
COPY packages/database ./packages/database
COPY packages/tomas-knowledge ./packages/tomas-knowledge
COPY apps/web ./apps/web

# Generate Prisma client (needed by some web imports)
RUN pnpm --filter @agoraencontrei/database generate

# Build Next.js (standalone output). tomas-knowledge is transpiled from
# source via next.config.mjs `transpilePackages`, so no explicit dist build
# is needed here.
RUN pnpm --filter @agoraencontrei/web build

# ── Production stage (smaller image) ──────────────────────────────────────────
FROM node:22-slim AS runner

RUN apt-get update -y && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV NODE_ENV=production
# Railway sets PORT dynamically; Next.js standalone reads HOSTNAME + PORT
ENV HOSTNAME="0.0.0.0"

# Copy standalone server using flat layout (proven approach)
COPY --from=base /app/apps/web/.next/standalone ./

# Copy static assets that standalone mode doesn't include automatically
COPY --from=base /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=base /app/apps/web/public ./apps/web/public

# Create wrapper at Railway's start command path so both CMD and Railway work
RUN mkdir -p apps/web/.next/standalone/apps/web && \
    echo 'require("/app/apps/web/server.js")' > apps/web/.next/standalone/apps/web/server.js

EXPOSE 3000

# Default CMD (Railway overrides with its own start command)
CMD ["node", "apps/web/server.js"]
