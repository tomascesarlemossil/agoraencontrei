# ──────────────────────────────────────────────────────────────
# Imobiliária Lemos — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Supabase (legacy — being migrated to TiDB MySQL backend) ──
# Kept for any remaining Supabase references during migration.
# New API calls use VITE_API_URL via @/lib/api instead.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend API ───────────────────────────────────────────────
# Development: http://localhost:3001
# Production:  https://api.agoraencontrei.com.br

VITE_API_URL=http://localhost:3001

# ── Application ───────────────────────────────────────────────

VITE_APP_NAME=AgoraEncontrei - Imóveis
VITE_APP_URL=https://www.agoraencontrei.com.br
VITE_APP_PHONE=(16) 3723-0045
VITE_APP_WHATSAPP=5516981010004

# ── Analytics (optional) ─────────────────────────────────────
# Google Analytics 4 Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── SEO Programático ────────────────────────────────────────
# API de IA para geração de conteúdo (pelo menos uma é necessária)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Cloudinary (Image Processing & Watermark) ──────────────
CLOUDINARY_CLOUD_NAME=agoraencontrei
CLOUDINARY_LOGO_ID=logo_agora_encontrei

# ── Gemini (Vision AI alternative) ──────────────────────────
GEMINI_API_KEY=

# ── Docker Local Dev ─────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agoraencontrei
# REDIS_URL=redis://localhost:6379
