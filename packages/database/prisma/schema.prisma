  description String    @db.Text
  type        String    @default("ANDAMENTO")

  userId      String?
  userName    String?

  createdAt   DateTime  @default(now())

  @@index([caseId])
  @@index([companyId])
  @@map("legal_case_updates")
}

// ── Alertas de Imóveis (notificações para interessados) ──────────────────────
model PropertyAlert {
