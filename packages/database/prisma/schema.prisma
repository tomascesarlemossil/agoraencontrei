}

// =============================================================================
// AUTOMATION ENGINE (Phase 4)
// =============================================================================

model AutomationRule {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  name            String
  description     String?
  trigger         String    // lead_created | lead_updated | deal_created | deal_status_changed | whatsapp_message | agent_job_done | schedule
  conditions      Json      @default("[]")  // ConditionRule[]
  actions         Json      @default("[]")  // ActionDef[]
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  logs            AutomationLog[]

  @@index([companyId])
  @@index([trigger, isActive])
  @@map("automation_rules")
}

model AutomationLog {
  id          String   @id @default(cuid())
  ruleId      String
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  triggeredBy String
  payload     Json     @default("{}")
  status      String   @default("pending") // pending | running | done | failed
  result      Json?
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([ruleId])
  @@index([status])
  @@index([createdAt])
  @@map("automation_logs")
}

// =============================================================================
// LEMOSBANK: CLIENTES LEGADOS + CONTRATOS + FINANCEIRO
// Migrado do sistema Visual FoxPro / planilhas XLS
// =============================================================================

enum ClientRole {
  TENANT      // Inquilino
  LANDLORD    // Proprietário
  GUARANTOR   // Fiador
  BENEFICIARY // Favorecido
  SECONDARY   // Secundário
}

enum ContractStatus {
  ACTIVE
  FINISHED
  CANCELED
  IN_RENEWAL
  EXPIRED
  IN_NEGOTIATION
}

enum RentalStatus {
  PENDING
  PAID
  LATE
  PARTIAL
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Client {
  id                  String       @id @default(cuid())
  companyId           String
  company             Company      @relation(fields: [companyId], references: [id])
  legacyId            String?      // row index or código legado
  name                String
  document            String?      // CPF ou CNPJ
  rg                  String?
  profession          String?
  birthDate           DateTime?
  email               String?
  phone               String?
  phoneMobile         String?
  phoneWork           String?
  address             String?
  addressComplement   String?
  neighborhood        String?
  city                String?
  state               String?
  zipCode             String?
  roles               ClientRole[]
  notes               String?
  // ── Dados complementares ─────────────────────────────────────────────────
  maritalStatus       String?      // solteiro | casado | divorciado | viuvo | uniao_estavel
  nationality         String?      // Brasileiro, Estrangeiro, etc.
  spouseName          String?      // Nome do cônjuge
  spouseDocument      String?      // CPF do cônjuge
  spouseProfession    String?      // Profissão do cônjuge
  income              Decimal?     @db.Decimal(12, 2)  // Renda mensal
  spouseIncome        Decimal?     @db.Decimal(12, 2)  // Renda do cônjuge
  bankName            String?      // Banco
  bankBranch          String?      // Agência
  bankAccount         String?      // Conta corrente
  bankAccountType     String?      // corrente | poupanca
  pixKey              String?      // Chave PIX
  observations        String?      // Observações internas detalhadas
  isArchived          Boolean      @default(false)  // Arquivo morto
  archivedAt          DateTime?    // Data de arquivamento
  archivedReason      String?      // Motivo do arquivamento
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  contractsAsLandlord  Contract[]        @relation("LandlordContracts")
  contractsAsTenant    Contract[]        @relation("TenantContracts")
  contractsAsGuarantor Contract[]        @relation("GuarantorContracts")
  forecasts            FinancialForecast[]
  documents            Document[]
  ownedDocuments       Document[]        @relation("DocumentOwner")
  legalCases           LegalCase[]
  @@unique([companyId, document])
  @@index([companyId])
  @@index([name])
  @@index([document])
  @@map("clients")
}

model Contract {
  id                String         @id @default(cuid())
  companyId         String
  company           Company        @relation(fields: [companyId], references: [id])
  legacyId          String?        // c_codcon
  legacyPropertyCode String?       // c_codimo
  propertyAddress   String?        // i_endereco
  iptuCode          String?        // i_num_iptu
  propertyId        String?        // FK → properties.id (linked after import)
  property          Property?      @relation(fields: [propertyId], references: [id])
  landlordId        String?
  landlord          Client?        @relation("LandlordContracts", fields: [landlordId], references: [id])
  tenantId          String?
  tenant            Client?        @relation("TenantContracts", fields: [tenantId], references: [id])
  guarantorId       String?
  guarantor         Client?        @relation("GuarantorContracts", fields: [guarantorId], references: [id])
  landlordName      String?        // locador (desnormalizado p/ histórico)
  tenantName        String?        // inquilino (desnormalizado)
  startDate         DateTime?      // c_inicio
  duration          Int?           // c_contra (meses)
  rentValue         Decimal?       @db.Decimal(12, 2)  // c_valor
  initialValue      Decimal?       @db.Decimal(12, 2)  // c_val_ini
  commission        Decimal?       @db.Decimal(5, 2)   // c_comissao %
  tenantDueDay      Int?           // c_venc_inq
  landlordDueDay    Int?           // c_venc_pro
  penalty           Decimal?       @db.Decimal(5, 2)   // c_multa %
  adjustmentBase    Decimal?       @db.Decimal(5, 2)   // c_database %
  adjustmentIndex   String?        // c_reajuste (IGPM, IPCA)
  adjustmentPercent Decimal?       @db.Decimal(5, 2)   // reaj_perce
  rescissionDate    DateTime?      // c_rescisao
  unit              String?        // c_unidade
  status            ContractStatus @default(ACTIVE)
  isActive          Boolean        @default(true)
  contractHtml      String?        @db.Text   // HTML do contrato gerado por IA
  guaranteeType     String?        // fiador | caucao | seguro

  // Encargos inclusos no aluguel (dados migrados do Uniloc)
  condoIncluded     Boolean        @default(false)
  waterIncluded     Boolean        @default(false)
  electricIncluded  Boolean        @default(false)
  iptuIncluded      Boolean        @default(false)

  // Rescisão detalhada
  rescissionReason  String?        // motivo da rescisão
  rescissionFine    Decimal?       @db.Decimal(12, 2) // multa rescisória
  rescissionRefund  Decimal?       @db.Decimal(12, 2) // devolução de caução
  rescissionNotes   String?        @db.Text

  // Renovação e Reajuste
  renewedFromId     String?        // contrato original que foi renovado
  renewalCount      Int            @default(0) // quantas vezes foi renovado
  lastAdjustmentAt  DateTime?      // data do último reajuste aplicado
  adjustmentMonth   Int?           // mês do reajuste anual (1-12, ex: 1=janeiro)
  iptuAnnual        Decimal?       @db.Decimal(12, 2) // valor anual do IPTU
  iptuParcels       Int?           // número de parcelas do IPTU (ex: 8, 10, 12)
  bankFee           Decimal?       @db.Decimal(12, 2) // taxa bancária por boleto (ex: 3.50)
  adminFeePercent   Decimal?       @db.Decimal(5, 2)  // taxa de administração % (comissão)

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  rentals           Rental[]
  invoices          Invoice[]
  documents         Document[]
  legalCases        LegalCase[]
  history           ContractHistory[]
  @@unique([companyId, legacyId])
  @@index([companyId])
  @@index([tenantId])
  @@index([landlordId])
  @@index([propertyId])
  @@index([status])
  @@map("contracts")
}

model Rental {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  legacyId        String?      // CODALUGUEL
  contractId      String?
  contract        Contract?    @relation(fields: [contractId], references: [id])
  dueDate         DateTime?
  rentAmount      Decimal?     @db.Decimal(12, 2)  // VLALUGUEL
  condoAmount     Decimal?     @db.Decimal(12, 2)  // VLCOND
  waterAmount     Decimal?     @db.Decimal(12, 2)  // VLAGUA
  electricAmount  Decimal?     @db.Decimal(12, 2)  // VLLUZ
  taxAmount       Decimal?     @db.Decimal(12, 2)  // VLTAXA
  penaltyAmount   Decimal?     @db.Decimal(12, 2)  // VLMULTA
  iptuAmount      Decimal?     @db.Decimal(12, 2)  // IPTU parcela mensal
  iptuParcela     String?                           // ex: "2/8" (parcela 2 de 8)
  bankFeeAmount   Decimal?     @db.Decimal(12, 2)  // taxa bancária
  adminFeeAmount  Decimal?     @db.Decimal(12, 2)  // taxa de administração
  totalAmount     Decimal?     @db.Decimal(12, 2)
  paidAmount      Decimal?     @db.Decimal(12, 2)  // VLPAGO
  paymentDate     DateTime?                         // DTPAGTO
  paymentMethod   String?                           // PIX | BOLETO | DINHEIRO | TRANSFERENCIA | CHEQUE | CARTAO
  proofReference  String?                           // nº comprovante ou referência
  bankName        String?                           // banco utilizado no pagamento
  observations    String?        @db.Text           // observações da baixa
  repassePaidAt   DateTime?                         // data em que o repasse foi pago ao proprietário
  status          RentalStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([status])
  @@index([dueDate])
  @@map("rentals")
}

model Transaction {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  legacyId        String?         // CODCAIXA
  transactionDate DateTime
  amount          Decimal         @db.Decimal(12, 2)
  type            TransactionType
  description     String?         // HISTORICO
  category        String?
  contractId      String?
  createdAt       DateTime        @default(now())

  @@index([companyId])
  @@index([transactionDate])
  @@index([type])
  @@map("transactions")
}

model FinancialForecast {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  legacyId         String?
  dueDate          DateTime
  amount           Decimal   @db.Decimal(12, 2)
  fee              Decimal?  @db.Decimal(12, 2)
  tenantName       String?
  tenantId         String?
  tenant           Client?   @relation(fields: [tenantId], references: [id])
  propertyAddress  String?
  landlordName     String?
  month            Int
  year             Int
  source           String    @default("forecast") // "forecast" | "realized"
  // Campos extras para importação das planilhas mensais
  clienteNome      String?
  proprietarioNome String?
  endereco         String?
  valorAluguel     Decimal?  @db.Decimal(12, 2)
  taxaAdm          Decimal?  @db.Decimal(12, 2)
  parcela          String?
  valorRepasse     Decimal?  @db.Decimal(12, 2)
  numeroBoleto     String?
  valorIptu        Decimal?  @db.Decimal(12, 2)
  forecastStatus   String    @default("PREVISTO") // PREVISTO | RECEBIDO | ATRASADO
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
  @@index([year, month])
  @@index([dueDate])
  @@map("financial_forecasts")
}

// ── NF-e / Notas Fiscais de Serviço ───────────────────────────────────────

enum FiscalNoteStatus {
  DRAFT
  ISSUED
  SENT
  RECEIVED
  CANCELLED
  ERROR
}

model FiscalNote {
  id                   String           @id @default(cuid())
  companyId            String
  company              Company          @relation(fields: [companyId], references: [id])
  landlordId           String?
  landlordName         String
  landlordCpf          String
  landlordEmail        String?
  landlordPhone        String?
  landlordAddress      String?
  propertyId           String?
  propertyAddress      String?
  rentalId             String?
  rentalMonth          Int
  rentalYear           Int
  rentalValue          Decimal          @db.Decimal(12, 2)
  serviceFeePercentage Decimal          @db.Decimal(5, 2)
  serviceFeeValue      Decimal          @db.Decimal(12, 2)
  serviceDescription   String           @default("Prestação de serviços de administração e intermediação imobiliária")
  invoiceNumber        String?
  invoiceSeries        String?          @default("UN")
  issueDate            DateTime         @default(now())
  nfeNumber            String?
  nfeKey               String?
  nfeXml               String?          @db.Text
  asaasNfeId           String?          // ID da NFS-e no Asaas
  asaasNfeStatus       String?          // PENDING | SCHEDULED | AUTHORIZED | ERROR
  asaasNfePdfUrl       String?          // URL do PDF da NFS-e no Asaas
  status               FiscalNoteStatus @default(DRAFT)
  createdById          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  logs                 FiscalNoteLog[]

  @@unique([rentalId, rentalMonth, rentalYear])
  @@index([companyId])
  @@index([landlordId])
  @@index([status])
  @@index([rentalMonth, rentalYear])
  @@map("fiscal_notes")
}

model FiscalNoteLog {
  id          String     @id @default(cuid())
  noteId      String
  note        FiscalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  action      String
  oldStatus   String?
  newStatus   String?
  details     Json?
  createdById String?
  createdAt   DateTime   @default(now())

  @@index([noteId])
  @@map("fiscal_note_logs")
}

// ── Asaas Boletos (legado) ─────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  legacyId        String?       // U_MOVIME do BOLETOS.DBF
  contractId      String?
  contract        Contract?     @relation(fields: [contractId], references: [id])
  // Legacy fields from BOLETOS.DBF
  legacyContractCode String?    // U_CODCON
  legacyTenantCode   String?    // U_CODINQ
  cedente         String?       // U_CEDENTE (IMOBILIARIA LEMOS)
  numBoleto       String?       // U_NUMBOL
  banco           String?       // U_BANCO / U_NBANCO
  carteira        String?       // U_CARTEIRA
  codigoBarras    String?       // U_NCODBAR
  linhaDigitavel  String?       // U_LINHADIG
  nossoNumero     String?       // U_NOSSONUM
  issueDate       DateTime?     // U_DATADOC
  dueDate         DateTime?     // U_VENCTO
  amount          Decimal?      @db.Decimal(12, 2)  // U_VALOR
  mensagem        String?       // U_MENSAGEM
  instrucoes      String?       // U_INSTRUCO
  // Asaas integration
  asaasId         String?       // ID retornado pela API Asaas
  asaasStatus     String?       // PENDING | RECEIVED | CONFIRMED | OVERDUE | REFUNDED
  asaasBankSlipUrl String?      // URL do boleto gerado pelo Asaas
  asaasPixCode    String?       // Código PIX Copia e Cola
  status          String?       @default("PENDING")  // PENDING | PAID | CANCELLED
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([dueDate])
  @@index([asaasId])
  @@map("invoices")
}


// ── IA Visual Jobs ─────────────────────────────────────────────────────────

model VisualAIJob {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  tipo        String    // render | staging | enhance_batch
  status      String    @default("PENDING") // PENDING | PROCESSING | DONE | ERROR
  inputUrl    String
  outputUrl   String?
  style       String?
  errorMsg    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([propertyId])
  @@index([status])
  @@map("visual_ai_jobs")
}

// ── Marketing Campanhas ────────────────────────────────────────────────────

model MarketingCampaign {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  nome          String
  tipo          String    // email | whatsapp
  segmento      String    // todos_clientes | proprietarios | inquilinos | leads_frios | custom
  mensagem      String    @db.Text
  status        String    @default("DRAFT") // DRAFT | SCHEDULED | SENDING | SENT | CANCELLED
  agendadoPara  DateTime?
  totalEnviados Int       @default(0)
  totalAbertos  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("marketing_campaigns")
}

// ── Blog Posts ─────────────────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  title       String
  slug        String
  excerpt     String?  @db.Text
  content     String   @db.Text
  coverImage  String?

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?  // comma-separated

  // Organization
  category    String?  // imoveis, financiamento, mercado, dicas, noticias, legislacao
  tags        String?  // comma-separated

  // Source (for auto-imported news)
  source      String?  // e.g. "CNN Brasil", "Valor Econômico"
  sourceUrl   String?
  isAutoImported Boolean @default(false)

  // Status
  published   Boolean  @default(false)
  publishedAt DateTime?
  featured    Boolean  @default(false)

  // Author
  authorName  String   @default("Equipe Imobiliária Lemos")

  views       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, published, publishedAt])
  @@map("blog_posts")
}

// =============================================================================
// DOCUMENTS (Locação: boletos, extratos, reajustes, contratos físicos)
// =============================================================================

model Document {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  contractId   String?
  contract     Contract? @relation(fields: [contractId], references: [id])
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  clientId     String?   // owner or tenant
  client       Client?   @relation(fields: [clientId], references: [id])
  ownerId      String?   // proprietário do imóvel (para boletos/extratos de proprietário)
  owner        Client?   @relation("DocumentOwner", fields: [ownerId], references: [id])
  legalCaseId  String?   // vínculo direto ao processo jurídico
  legalCase    LegalCase? @relation(fields: [legalCaseId], references: [id])
  uploadedBy   String?   // user id
  user         User?     @relation(fields: [uploadedBy], references: [id])

  type         String    // BOLETO | EXTRATO | REAJUSTE | FINANCEIRO | CONTRATO | JURIDICO | OUTROS
  category     String?
  name         String
  month        String?   // stored as text (e.g. "04.2026", "MARÇO", or numeric month)
  year         Int?
  fileData     Bytes?
  mimeType     String?
  fileSize     Int?
  legacyRef    String?   // original folder/filename ref for matching
  metadata     Json      @default("{}")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([propertyId])
  @@index([clientId])
  @@index([ownerId])
  @@index([legalCaseId])
  @@map("documents")
}

// ── Módulo Jurídico ───────────────────────────────────────────────────────────

model LegalCase {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])

  caseNumber    String?
  title         String
  type          String    // DESPEJO | COBRANCA | REVISIONAL | RESCISAO | DANO | OUTROS
  status        String    @default("ATIVO")

  plaintiffName String?
  defendantName String?
  lawyerName    String?
  lawyerOab     String?
  lawyerPhone   String?
  lawyerEmail   String?

  court         String?
  courtSection  String?
  courtCity     String?

  openedAt      DateTime?
  closedAt      DateTime?
  nextHearingAt DateTime?

  claimedValue  Float?
  settledValue  Float?
  courtCosts    Float?

  contractId    String?
  contract      Contract? @relation(fields: [contractId], references: [id])
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])

  observations  String?   @db.Text
  internalNotes String?   @db.Text
  priority      String    @default("NORMAL")
  tags          String[]  @default([])
  metadata      Json      @default("{}")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  updates       LegalCaseUpdate[]
  documents     Document[]

  @@index([companyId])
  @@index([contractId])
  @@index([clientId])
  @@index([propertyId])
  @@index([status])
  @@index([type])
  @@map("legal_cases")
}

model LegalCaseUpdate {
  id          String    @id @default(cuid())
  caseId      String
  case        LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  companyId   String

  date        DateTime  @default(now())
  description String    @db.Text
  type        String    @default("ANDAMENTO")

  userId      String?
  userName    String?

  createdAt   DateTime  @default(now())

  @@index([caseId])
  @@index([companyId])
  @@map("legal_case_updates")
}

// ── Histórico de Contratos ────────────────────────────────────────────────────
model ContractHistory {
  id            String    @id @default(cuid())
  contractId    String
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  companyId     String

  action        String    // REAJUSTE | RENOVACAO | RESCISAO | ALTERACAO | CRIACAO
  description   String    @db.Text
  field         String?   // campo alterado (ex: rentValue, status)
  oldValue      String?   // valor anterior
  newValue      String?   // valor novo

  userId        String?
  userName      String?

  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())

  @@index([contractId])
  @@index([companyId])
  @@index([action])
  @@map("contract_history")
}

// =============================================================================
// PROPERTY ALERTS
// =============================================================================

model PropertyAlert {
  id        String   @id @default(cuid())
  email     String
  city      String?
  type      String?
  purpose   String?
  minPrice  Float?
  maxPrice  Float?
  bedrooms  Int?
  active    Boolean  @default(true)
  token     String   @default(cuid())
  createdAt DateTime @default(now())

  @@index([email])
  @@index([active])
  @@map("property_alerts")
}
