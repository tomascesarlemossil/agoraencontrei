// =============================================================================
// BLOG MODULE: Categories, Clusters, Posts
// =============================================================================

model BlogCategory {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  name        String
  slug        String
  description String?  @db.Text
  image       String?

  // SEO
  seoTitle       String?
  metaDescription String?

  // Organization
  ordem       Int      @default(0)
  status      String   @default("active") // active, inactive

  posts       BlogPost[]
  clusters    BlogCluster[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, status])
  @@map("blog_categories")
}

model BlogCluster {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  name        String
  slug        String
  description String?  @db.Text

  // Relationships
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  pillarPostId String?  // The main pillar post for this cluster

  // SEO
  seoTitle       String?
  metaDescription String?

  status      String   @default("active") // active, inactive

  posts       BlogPost[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, status])
  @@map("blog_clusters")
}

model BlogPost {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  // ── Core Content ──
  title       String
  subtitle    String?
  slug        String
  excerpt     String?  @db.Text
  content     String   @db.Text        // HTML content
  bodyMarkdown String? @db.Text        // Original markdown source

  // ── Cover & Media ──
  coverImage     String?
  coverImageAlt  String?
  coverImageCaption String?
  galleryImages  Json?    @default("[]")  // [{url, alt, caption, order}]
  videoUrl       String?
  videoEmbed     String?  @db.Text

  // ── Organization ──
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  clusterId   String?
  cluster     BlogCluster?  @relation(fields: [clusterId], references: [id])
  tags        String?  // comma-separated

  // ── SEO ──
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?  // comma-separated (legacy compat)
  keywordPrincipal    String?
  keywordsSecundarias String?  @db.Text // semicolon-separated
  canonicalUrl   String?
  noindex        Boolean  @default(false)

  // ── Open Graph & Twitter ──
  ogTitle        String?
  ogDescription  String?
  ogImage        String?
  twitterTitle   String?
  twitterDescription String?
  twitterImage   String?

  // ── Schema & Breadcrumb ──
  schemaType     String?  @default("BlogPosting") // BlogPosting, Article
  breadcrumbLabel String?

  // ── Editorial Strategy ──
  intencaoBusca     String?  // informacional, comercial, comparacao, etc.
  estagioFunil      String?  // TOFU, MOFU, BOFU
  ctaFinal          String?  @db.Text
  faq               Json?    @default("[]") // [{question, answer}]
  linksInternos     Json?    @default("[]") // [{url, anchor}]
  postsRelacionados Json?    @default("[]") // [slugs]

  // ── Location & Property ──
  cidade         String?
  bairro         String?
  tipoImovel     String?  // geral, casa, apartamento, terreno, comercial, rural

  // ── Priority & Notes ──
  seoPriority        Int?     @default(0)
  commercialPriority Int?     @default(0)
  editorialNotes     String?  @db.Text
  cannibalizationNotes String? @db.Text

  // ── Source (for auto-imported news) ──
  source      String?
  sourceUrl   String?
  isAutoImported Boolean @default(false)

  // ── Status & Publishing ──
  status      String   @default("draft") // draft, published, scheduled
  published   Boolean  @default(false)
  publishedAt DateTime?
  scheduledAt DateTime?
  featured    Boolean  @default(false)

  // ── Author ──
  authorName  String   @default("Equipe AgoraEncontrei")

  views       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId, published, publishedAt])
  @@index([companyId, status])
  @@index([categoryId])
  @@index([clusterId])
  @@index([cidade])
  @@map("blog_posts")
}

// =============================================================================
// DOCUMENTS (Locação: boletos, extratos, reajustes, contratos físicos)
// =============================================================================

model Document {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  contractId   String?
  contract     Contract? @relation(fields: [contractId], references: [id])
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  clientId     String?   // owner or tenant
  client       Client?   @relation(fields: [clientId], references: [id])
  ownerId      String?   // proprietário do imóvel (para boletos/extratos de proprietário)
  owner        Client?   @relation("DocumentOwner", fields: [ownerId], references: [id])
  legalCaseId  String?   // vínculo direto ao processo jurídico
  legalCase    LegalCase? @relation(fields: [legalCaseId], references: [id])
  uploadedBy   String?   // user id
  user         User?     @relation(fields: [uploadedBy], references: [id])

  type         String    // BOLETO | EXTRATO | REAJUSTE | FINANCEIRO | CONTRATO | JURIDICO | OUTROS
  category     String?
  name         String
  month        String?   // stored as text (e.g. "04.2026", "MARÇO", or numeric month)
  year         Int?
  fileData     Bytes?
  mimeType     String?
  fileSize     Int?
  legacyRef    String?   // original folder/filename ref for matching
  metadata     Json      @default("{}")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([propertyId])
  @@index([clientId])
  @@index([ownerId])
  @@index([legalCaseId])
  @@map("documents")
}

// ── Módulo Jurídico ───────────────────────────────────────────────────────────

model LegalCase {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])

  caseNumber    String?
  title         String
  type          String    // DESPEJO | COBRANCA | REVISIONAL | RESCISAO | DANO | OUTROS
  status        String    @default("ATIVO")

  plaintiffName String?
  defendantName String?
  lawyerName    String?
  lawyerOab     String?
  lawyerPhone   String?
  lawyerEmail   String?

  court         String?
  courtSection  String?
  courtCity     String?

  openedAt      DateTime?
  closedAt      DateTime?
  nextHearingAt DateTime?

  claimedValue  Float?
  settledValue  Float?
  courtCosts    Float?

  contractId    String?
  contract      Contract? @relation(fields: [contractId], references: [id])
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])

  observations  String?   @db.Text
  internalNotes String?   @db.Text
