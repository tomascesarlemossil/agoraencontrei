// =============================================================================
// AgoraEncontrei + Lemosbank — Prisma Schema
// Fase 1: Infraestrutura Base
// PostgreSQL (Neon)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  BROKER
  FINANCIAL
  LAWYER
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  SUSPENDED
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  FARM
  RANCH
  WAREHOUSE
  OFFICE
  STORE
  STUDIO
  PENTHOUSE
  CONDO
  KITNET
}

enum PropertyPurpose {
  SALE
  RENT
  BOTH
  SEASON
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  SOLD
  RENTED
  PENDING
  DRAFT
}

enum PropertyCategory {
  RESIDENTIAL
  COMMERCIAL
  RURAL
  INDUSTRIAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VISITING
  PROPOSAL
  NEGOTIATING
  WON
  LOST
  ARCHIVED
}

enum DealStatus {
  OPEN
  IN_PROGRESS
  PROPOSAL
  CONTRACT
  CLOSED_WON
  CLOSED_LOST
}

enum NegotiationType {
  SALE
  RENT
}

enum ContactType {
  INDIVIDUAL
  COMPANY
}

enum CommissionStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

// =============================================================================
// CORE: COMPANY (Imobiliária)
// =============================================================================

model Company {
  id          String   @id @default(cuid())
  name        String
  tradeName   String?
  cnpj        String?  @unique
  creci       String?
  phone       String?
  email       String?
  website     String?
  logoUrl     String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  plan        String   @default("starter")
  settings    Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  properties  Property[]
  contacts    Contact[]
  leads       Lead[]
  deals       Deal[]
  commissions   Commission[]
  financings    Financing[]
  portals       PortalConfig[]
  conversations Conversation[]
  agentJobs     AgentJob[]
  automationRules AutomationRule[]
  clients         Client[]
  contracts       Contract[]
  rentals         Rental[]
  transactions    Transaction[]
  financialForecasts FinancialForecast[]
  invoices        Invoice[]
  fiscalNotes       FiscalNote[]
  visualAIJobs      VisualAIJob[]
  marketingCampaigns MarketingCampaign[]
  blogPosts         BlogPost[]
  documents         Document[]
  legalCases        LegalCase[]

  @@map("companies")
}

// =============================================================================
// AUTH: USERS + SESSIONS
// =============================================================================

model User {
  id                String      @id @default(cuid())
  companyId         String
  company           Company     @relation(fields: [companyId], references: [id])
  name              String
  email             String      @unique
  phone             String?
  passwordHash      String?
  avatarUrl         String?
  role              UserRole    @default(BROKER)
  status            UserStatus  @default(PENDING_VERIFICATION)
  creciNumber       String?
  bio               String?
  settings          Json        @default("{}")
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  sessions              Session[]
  oauthAccounts         OAuthAccount[]
  properties            Property[]
  leads                 Lead[]         @relation("BrokerLeads")
  assignedLeads         Lead[]         @relation("AssignedLeads")
  deals                 Deal[]
  commissions           Commission[]
  financings            Financing[]    @relation("BrokerFinancings")
  activities            Activity[]
  refreshTokens         RefreshToken[]
  assignedConversations Conversation[]
  visualAIJobs          VisualAIJob[]
  documents             Document[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique @default(cuid())
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  family      String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model OAuthAccount {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         String   // "google" | "facebook"
  providerUserId   String
  accessToken      String?
  refreshToken     String?
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_resets")
}

// =============================================================================
// CONTACTS (Clientes, Proprietários, Inquilinos)
// =============================================================================

model Contact {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  type          ContactType @default(INDIVIDUAL)
  name          String
  email         String?
  phone         String?
  mobilePhone   String?
  cpf           String?
  cnpj          String?
  rg            String?
  birthDate     DateTime?
  address       String?
  neighborhood  String?
  city          String?
  state         String?
  zipCode       String?
  notes         String?
  tags          String[]
  isOwner       Boolean     @default(false)
  isTenant      Boolean     @default(false)
  isGuarantor   Boolean     @default(false)
  externalId    String?     // Uniloc CODINQ / CODLOC
  source        String?     // "uniloc", "manual", "portal", "whatsapp"
  metadata      Json        @default("{}")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  leads         Lead[]
  deals         Deal[]
  financings    Financing[]
  activities    Activity[]
  ownedProperties PropertyOwner[]
  conversations Conversation[]

  @@index([companyId])
  @@index([email])
  @@index([cpf])
  @@index([externalId])
  @@map("contacts")
}

// =============================================================================
// PROPERTIES
// =============================================================================

model Property {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  reference       String?          // ex: LEM-0087
  externalId      String?          // Univen ID Internet
  title           String
  slug            String
  description     String?
  type            PropertyType     @default(HOUSE)
  purpose         PropertyPurpose  @default(SALE)
  category        PropertyCategory @default(RESIDENTIAL)
  status          PropertyStatus   @default(ACTIVE)

  // Pricing
  price           Decimal?         @db.Decimal(12, 2)
  priceRent       Decimal?         @db.Decimal(12, 2)
  priceSeason     Decimal?         @db.Decimal(12, 2)
  priceNegotiable Boolean          @default(false)
  condoFee        Decimal?         @db.Decimal(10, 2)
  iptu            Decimal?         @db.Decimal(10, 2)

  // Location
  zipCode         String?
  street          String?
  number          String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  country         String           @default("BR")
  latitude        Float?
  longitude       Float?
  showAddress     Boolean          @default(true)
  condoName       String?

  // Characteristics
  totalArea       Float?
  builtArea       Float?
  landArea        Float?
  bedrooms        Int              @default(0)
  suites          Int              @default(0)
  bathrooms       Int              @default(0)
  parkingSpaces   Int              @default(0)
  floor           Int?
  totalFloors     Int?
  yearBuilt       Int?

  // Media
  coverImage      String?
  images          String[]
  videoUrl        String?
  videos          String[]         // uploaded video URLs (mp4, mov, webm)
  virtualTourUrl  String?

  // Features & amenities
  features        String[]         // ["pool", "gym", "barbecue", ...]

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]

  // Portal descriptions (per portal AI-generated)
  portalDescriptions Json          @default("{}")

  // Analytics
  views           Int              @default(0)
  favorites       Int              @default(0)
  leads           Int              @default(0)

  // Flags
  isFeatured      Boolean          @default(false)
  isPremium       Boolean          @default(false)
  isHighlighted   Boolean          @default(false)
  featuredUntil   DateTime?

  // Extended pricing
  pricePromo      Decimal?         @db.Decimal(12, 2)   // Preço promocional
  pricePerM2      Decimal?         @db.Decimal(10, 2)   // Preço por M²
  allowExchange   Boolean          @default(false)       // Aceita permuta
  valueUnderConsultation Boolean   @default(false)       // Valor sob consulta

  // Commercial details
  currentState    String?          // Desocupado / Ocupado Proprietário / Ocupado Inquilino
  occupation      String?          // Residencial / Comercial / Misto
  standard        String?          // SIMPLE / NORMAL / HIGH / LUXURY
  auxReference    String?          // Referência auxiliar

  // Extended location
  commercialNeighborhood String?   // Bairro comercial (exibido no site)
  region          String?          // Região
  referencePoint  String?          // Ponto de referência
  closedCondo     Boolean          @default(false)
  adminCompany    String?          // Administradora
  constructionCompany String?      // Construtora
  signOnSite      Boolean          @default(false)       // Placa no local

  // Extended rooms breakdown
  suitesWithCloset Int             @default(0)
  demiSuites      Int              @default(0)
  rooms           Int              @default(0)           // Salas (total)
  livingRooms     Int              @default(0)           // Sala de estar
  diningRooms     Int              @default(0)           // Sala de jantar
  tvRooms         Int              @default(0)           // Salas de TV
  garagesCovered  Int              @default(0)
  garagesOpen     Int              @default(0)
  elevators       Int              @default(0)

  // Extended areas
  commonArea      Float?           // Área comum
  ceilingHeight   Float?           // Pé direto
  landDimensions  String?          // Dimensão terreno (ex: 10x20)
  landFace        String?          // Face do terreno
  sunExposure     String?          // Insolamento
  position        String?          // Posição (frente/fundos/meio)

  // Internal notes (not published)
  descriptionInternal String?

  // Confidential / documentation
  cib             String?          // Código Imobiliário Brasileiro
  iptuRegistration String?         // Cadastro Prefeitura / INCRA
  cartorioMatricula String?        // Cartório - Nº Matrícula
  electricityInfo String?          // Eletricidade (concessionária)
  waterInfo       String?          // Água e Saneamento
  documentationPending Boolean     @default(false)
  documentationNotes String?       // Obs. documentação
  isReserved      Boolean          @default(false)
  authorizedPublish Boolean        @default(false)       // Autorizado para publicar
  showExactLocation Boolean        @default(false)       // Exibir localização exata no mapa (padrão: aproximada)

  // Captação
  captorName      String?          // Nome do captador principal
  captorCommissionPct Float?       // Comissão do captador (%)
  exclusivityContract Boolean      @default(false)
  commercialConditions String?     // Condições comerciais
  yearLastReformed Int?            // Ano da última reforma
  keyLocation     String?          // Local das chaves

  // Import metadata
  importSource    String?          // "univen_xls", "manual", "portal_xml"
  importedAt      DateTime?

  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  owners          PropertyOwner[]
  portalPublications PortalPublication[]
  dealProperties  DealProperty[]
  leadProperties  LeadProperty[]
  financings      Financing[]
  activities      Activity[]
  visualAIJobs    VisualAIJob[]
  contracts       Contract[]
  documents       Document[]
  legalCases      LegalCase[]
  @@unique([companyId, slug])
  @@unique([companyId, reference])
  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([type, purpose])
  @@index([city, neighborhood])
  @@index([externalId])
  // Performance indexes for public listing queries (Manus recommendation)
  @@index([companyId, status, authorizedPublish])
  @@index([companyId, status, authorizedPublish, type])
  @@index([companyId, status, authorizedPublish, isFeatured])
  @@index([companyId, status, authorizedPublish, createdAt(sort: Desc)])
  @@map("properties")
}

model PropertyOwner {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id])
  percentage  Decimal  @default(100) @db.Decimal(5, 2)
  createdAt   DateTime @default(now())

  @@unique([propertyId, contactId])
  @@map("property_owners")
}

// =============================================================================
// PORTALS
// =============================================================================

model PortalConfig {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  portalId    String   // "olx", "zap", "vivareal", "facebook", ...
  portalName  String
  apiKey      String?
  apiSecret   String?
  settings    Json     @default("{}")
  isActive    Boolean  @default(false)
  isPaid      Boolean  @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, portalId])
  @@map("portal_configs")
}

model PortalPublication {
  id           String    @id @default(cuid())
  propertyId   String
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  portalId     String
  externalId   String?
  status       String    @default("pending")  // pending, published, failed, removed
  publishedAt  DateTime?
  errorMsg     String?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([propertyId, portalId])
  @@map("portal_publications")
}

// =============================================================================
// CRM: LEADS + DEALS
// =============================================================================

model Lead {
  id            String     @id @default(cuid())
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?   @relation(fields: [contactId], references: [id])
  brokerId      String?    // who captured
  broker        User?      @relation("BrokerLeads", fields: [brokerId], references: [id])
  assignedToId  String?    // who is responsible now
  assignedTo    User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  name          String
  email         String?
  phone         String?
  status        LeadStatus @default(NEW)
  source        String?    // "whatsapp", "portal", "site", "referral", "manual"
  interest      String?    // "buy", "rent"
  budget        Decimal?   @db.Decimal(12, 2)
  notes         String?
  score         Int        @default(0)
  tags          String[]
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  metadata      Json       @default("{}")
  lastContactAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  properties    LeadProperty[]
  deals         Deal[]
  activities    Activity[]
  conversations Conversation[]

  @@index([companyId])
  @@index([brokerId])
  @@index([assignedToId])
  @@index([status])
  @@map("leads")
}

model LeadProperty {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([leadId, propertyId])
  @@map("lead_properties")
}

model Deal {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  leadId        String?
  lead          Lead?           @relation(fields: [leadId], references: [id])
  brokerId      String
  broker        User            @relation(fields: [brokerId], references: [id])
  contactId     String?
  contact       Contact?        @relation(fields: [contactId], references: [id])
  title         String
  type          NegotiationType @default(SALE)
  status        DealStatus      @default(OPEN)
  value         Decimal?        @db.Decimal(12, 2)
  commission    Decimal?        @db.Decimal(5, 2)
  notes         String?
  closedAt      DateTime?
  expectedCloseAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  properties    DealProperty[]
  commissions   Commission[]
  financings    Financing[]
  activities    Activity[]

  @@index([companyId])
  @@index([brokerId])
  @@index([status])
  @@map("deals")
}

model DealProperty {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([dealId, propertyId])
  @@map("deal_properties")
}

// =============================================================================
// LEMOSBANK: COMMISSION TRACKING
// =============================================================================

model Commission {
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  dealId           String
  deal             Deal             @relation(fields: [dealId], references: [id])
  brokerId         String
  broker           User             @relation(fields: [brokerId], references: [id])
  dealValue        Decimal          @db.Decimal(12, 2)
  commissionRate   Decimal          @db.Decimal(5, 2)   // percentage e.g. 6.00
  grossValue       Decimal          @db.Decimal(12, 2)  // dealValue * commissionRate / 100
  splitRate        Decimal          @db.Decimal(5, 2)   @default(100) // broker's share %
  netValue         Decimal          @db.Decimal(12, 2)  // grossValue * splitRate / 100
  status           CommissionStatus @default(PENDING)
  paidAmount       Decimal          @db.Decimal(12, 2)  @default(0)
  paidAt           DateTime?
  dueAt            DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([companyId])
  @@index([brokerId])
  @@index([dealId])
  @@index([status])
  @@map("commissions")
}

// =============================================================================
// FINANCIAMENTOS
// =============================================================================

enum FinancingStage {
  SIMULACAO
  ANALISE_CREDITO
  ANALISE_JURIDICA
  EMISSAO_CONTRATO
  REGISTRO_CONTRATO
  CONCLUIDO
  CANCELADO
}

model Financing {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  brokerId        String
  broker          User           @relation("BrokerFinancings", fields: [brokerId], references: [id])
  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id])
  propertyId      String?
  property        Property?      @relation(fields: [propertyId], references: [id])
  dealId          String?
  deal            Deal?          @relation(fields: [dealId], references: [id])
  stage           FinancingStage @default(SIMULACAO)
  bank            String?        // Nome do banco
  propertyValue   Decimal?       @db.Decimal(14, 2)
  financedValue   Decimal?       @db.Decimal(14, 2)
  downPayment     Decimal?       @db.Decimal(14, 2)
  fgtsValue       Decimal?       @db.Decimal(14, 2)
  monthlyPayment  Decimal?       @db.Decimal(12, 2)
  term            Int?           // Prazo em meses
  rate            Decimal?       @db.Decimal(5, 4) // Taxa de juros anual
  notes           String?
  simulatorLink   String?        // Link do simulador para o cliente
  clientName      String?
  clientPhone     String?
  clientEmail     String?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([brokerId])
  @@index([stage])
  @@index([createdAt])
  @@map("financings")
}

// =============================================================================
// ACTIVITIES (Timeline unificado)
// =============================================================================

model Activity {
  id          String    @id @default(cuid())
  companyId   String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id])
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id])
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
  type        String    // "note", "call", "email", "visit", "whatsapp", "status_change", "system"
  title       String
  description String?
  metadata    Json      @default("{}")
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([contactId])
  @@index([leadId])
  @@index([dealId])
  @@index([propertyId])
  @@map("activities")
}

// =============================================================================
// SYSTEM: API KEYS + AUDIT LOG
// =============================================================================

model ApiKey {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  name        String
  keyHash     String   @unique
  prefix      String   // first 8 chars for display
  scopes      String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@map("api_keys")
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?
  userId      String?
  action      String   // "user.login", "property.create", "deal.close", ...
  resource    String?
  resourceId  String?
  ipAddress   String?
  userAgent   String?
  payload     Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// =============================================================================
// LEMOS.CHAT — WhatsApp Omnichannel
// =============================================================================

model Conversation {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  phone         String                        // E.164 e.g. +5511999999999
  contactName   String?
  channel       String    @default("whatsapp") // "whatsapp", "email", "portal"
  status        String    @default("bot")      // "bot", "open", "assigned", "resolved"
  assignedToId  String?
  assignedTo    User?     @relation(fields: [assignedToId], references: [id])
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])
  contactId     String?
  contact       Contact?  @relation(fields: [contactId], references: [id])
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  botState      Json      @default("{}")       // current qualification flow state
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      Message[]

  @@unique([companyId, phone])
  @@index([companyId])
  @@index([status])
  @@index([assignedToId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  whatsappId     String?      // WhatsApp message ID for dedup
  direction      String       // "inbound", "outbound"
  type           String       // "text", "audio", "image", "document", "template", "interactive"
  content        String?
  mediaUrl       String?
  mediaKey       String?      // S3 key
  status         String       @default("sent") // "sent", "delivered", "read", "failed"
  sentBy         String?      // userId if human, "bot" if automated, null if inbound
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([whatsappId])
  @@map("messages")
}

// =============================================================================
// AI AGENTS
// =============================================================================

model AgentJob {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  type        String    // "pdf_extract", "audio_transcribe", "copywrite", "score_lead"
  status      String    @default("pending") // "pending", "processing", "done", "failed"
  input       Json      @default("{}")      // { url, propertyId, ... }
  output      Json?                         // extracted data / generated text
  errorMsg    String?
  propertyId  String?
  leadId      String?
  dealId      String?
  contactId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([type, status])
  @@index([propertyId])
  @@index([leadId])
