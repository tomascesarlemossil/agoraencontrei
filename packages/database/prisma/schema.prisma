// ======================================================================
enum AuctionSource {
  CAIXA
  BANCO_DO_BRASIL
  BRADESCO
  ITAU
  SANTANDER
  LEILOEIRO
  JUDICIAL
  EXTRAJUDICIAL
  MANUAL
}

enum AuctionStatus {
  UPCOMING       // Próximo
  OPEN           // Aberto para lances
  FIRST_ROUND    // 1ª Praça
  SECOND_ROUND   // 2ª Praça
  SOLD           // Arrematado
  DESERTED       // Deserto (sem lances)
  SUSPENDED      // Suspenso
  CANCELLED      // Cancelado
  CLOSED         // Encerrado
}

enum AuctionModality {
  ONLINE         // Leilão online
  PRESENTIAL     // Leilão presencial
  HYBRID         // Online + presencial
  DIRECT_SALE    // Venda direta (bancos)
}

model Auction {
  id                  String          @id @default(cuid())
  companyId           String?
  company             Company?        @relation(fields: [companyId], references: [id])

  // Identificação
  externalId          String?         // ID da fonte original
  source              AuctionSource   @default(LEILOEIRO)
  sourceUrl           String?         // URL original do leilão
  auctioneerName      String?         // Nome do leiloeiro
  auctioneerUrl       String?         // Site do leiloeiro
  auctioneerCnpj      String?
  auctioneerJucesp    String?         // Registro Junta Comercial

  // Status
  status              AuctionStatus   @default(UPCOMING)
  modality            AuctionModality @default(ONLINE)

  // Imóvel
  title               String
  slug                String          @unique
  description         String?         @db.Text
  propertyType        PropertyType    @default(HOUSE)
  category            PropertyCategory @default(RESIDENTIAL)

  // Localização
  street              String?
  number              String?
  complement          String?
  neighborhood        String?
  city                String?
  state               String?
  zipCode             String?
  latitude            Float?
  longitude           Float?

  // Áreas
  totalArea           Float?
  builtArea           Float?
  landArea            Float?
  bedrooms            Int             @default(0)
  bathrooms           Int             @default(0)
  parkingSpaces       Int             @default(0)

  // Valores
  appraisalValue      Decimal?        @db.Decimal(14, 2) // Valor de avaliação
  minimumBid          Decimal?        @db.Decimal(14, 2) // Lance mínimo
  firstRoundBid       Decimal?        @db.Decimal(14, 2) // Lance 1ª praça
  secondRoundBid      Decimal?        @db.Decimal(14, 2) // Lance 2ª praça
  currentBid          Decimal?        @db.Decimal(14, 2) // Lance atual
  soldValue           Decimal?        @db.Decimal(14, 2) // Valor arrematado
  discountPercent     Float?          // % desconto sobre avaliação

  // Custos estimados
  itbiEstimate        Decimal?        @db.Decimal(12, 2)
  registryEstimate    Decimal?        @db.Decimal(12, 2)
  lawyerEstimate      Decimal?        @db.Decimal(12, 2)
  evictionEstimate    Decimal?        @db.Decimal(12, 2)

  // Datas
  firstRoundDate      DateTime?
  secondRoundDate     DateTime?
  auctionDate         DateTime?       // Data principal do leilão
  auctionEndDate      DateTime?       // Data fim (online)
  visitDate           DateTime?

  // Detalhes jurídicos
  processNumber       String?         // Nº processo judicial
  court               String?         // Vara/Foro
  judge               String?
  registryNumber      String?         // Matrícula
  registryOffice      String?         // Cartório
  debtorName          String?
  creditorName        String?
  occupation          String?         // OCUPADO | DESOCUPADO | DESCONHECIDO
  hasDebts            Boolean?        // Dívidas pendentes (IPTU, condomínio)
  debtDetails         String?         @db.Text
  restrictions        String?         @db.Text // Ônus, gravames
  editalUrl           String?         // URL do edital

  // Banco (para leilões de bancos)
  bankName            String?
  bankBranch          String?
  financingAvailable  Boolean         @default(false)
  fgtsAllowed         Boolean         @default(false)

  // Mídia
  coverImage          String?
  images              String[]
  documentsUrls       String[]        // Links para editais, laudos

  // Score de oportunidade (calculado pela IA)
  opportunityScore    Int?            // 0-100
  estimatedROI        Float?          // ROI estimado %
  marketPriceEstimate Decimal?        @db.Decimal(14, 2)
  pricePerM2          Decimal?        @db.Decimal(10, 2)

  // Metadata
  features            String[]
  tags                String[]        @default([])
  metadata            Json            @default("{}")

  // Scraper tracking
  lastScrapedAt       DateTime?
  scrapedHash         String?         // Hash para detectar mudanças
  isVerified          Boolean         @default(false)

  // Analytics
  views               Int             @default(0)
  favorites           Int             @default(0)
  alertsSent          Int             @default(0)

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  bids                AuctionBid[]
  alerts              AuctionAlert[]
  analyses            AuctionAnalysis[]

  @@index([source])
  @@index([status])
  @@index([city, state])
  @@index([propertyType])
  @@index([auctionDate])
  @@index([minimumBid])
  @@index([discountPercent])
  @@index([opportunityScore])
  @@index([slug])
  @@index([externalId, source])
  @@map("auctions")
}

model AuctionBid {
  id          String   @id @default(cuid())
  auctionId   String
  auction     Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  round       Int      @default(1) // 1ª ou 2ª praça
  bidValue    Decimal  @db.Decimal(14, 2)
  bidderName  String?
  bidderCpf   String?
  bidDate     DateTime @default(now())
  isWinning   Boolean  @default(false)
  metadata    Json     @default("{}")

  @@index([auctionId])
  @@map("auction_bids")
}

model AuctionAlert {
  id            String   @id @default(cuid())
  email         String?
  phone         String?  // WhatsApp
  userId        String?

  // Filtros do alerta
  city          String?
  state         String?
  propertyType  String?
  minDiscount   Float?   // % mínimo de desconto
  maxPrice      Decimal? @db.Decimal(14, 2)
  minScore      Int?     // Score mínimo de oportunidade
  source        String?  // CAIXA, JUDICIAL, etc
  keywords      String[] @default([])

  // Controle
  active        Boolean  @default(true)
  token         String?  @unique @default(cuid())
  lastSentAt    DateTime?
  sentCount     Int      @default(0)
  frequency     String   @default("DAILY") // INSTANT | DAILY | WEEKLY

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auctionId     String?
  auction       Auction? @relation(fields: [auctionId], references: [id])

  @@index([email])
  @@index([phone])
  @@index([city])
  @@index([active])
  @@map("auction_alerts")
}

model AuctionAnalysis {
  id              String   @id @default(cuid())
  auctionId       String
  auction         Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  // Análise financeira
  totalCost       Decimal? @db.Decimal(14, 2) // Lance + custos
  marketValue     Decimal? @db.Decimal(14, 2) // Valor estimado mercado
  potentialProfit Decimal? @db.Decimal(14, 2) // Lucro potencial
  roiPercent      Float?
  paybackMonths   Int?     // Meses para recuperar investimento

  // Custos detalhados
  bidValue        Decimal? @db.Decimal(14, 2)
  itbiValue       Decimal? @db.Decimal(12, 2)
  registryValue   Decimal? @db.Decimal(12, 2)
  lawyerValue     Decimal? @db.Decimal(12, 2)
  reformValue     Decimal? @db.Decimal(12, 2)
  evictionValue   Decimal? @db.Decimal(12, 2)
  otherCosts      Decimal? @db.Decimal(12, 2)

  // Score IA
  score           Int?     // 0-100
  riskLevel       String?  // LOW | MEDIUM | HIGH
  recommendation  String?  @db.Text // Recomendação da IA
  aiModel         String?  // Modelo usado

  createdAt       DateTime @default(now())

  @@index([auctionId])
  @@map("auction_analyses")
}

// Controle dos scrapers — qual fonte foi atualizada quando
model ScraperRun {
  id            String   @id @default(cuid())
  source        String   // CAIXA, LEILOEIRO_xxx, etc
  sourceUrl     String?
  status        String   @default("RUNNING") // RUNNING | SUCCESS | FAILED | PARTIAL
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  itemsFound    Int      @default(0)
  itemsCreated  Int      @default(0)
  itemsUpdated  Int      @default(0)
  itemsRemoved  Int      @default(0)
  errorMessage  String?  @db.Text
  metadata      Json     @default("{}")

  @@index([source])
  @@index([status])
  @@index([startedAt])
  @@map("scraper_runs")
}

// ─── ESPECIALISTAS / PARCEIROS PROFISSIONAIS ────────────────────────────────

enum SpecialistCategory {
  ARQUITETO
  ENGENHEIRO
  CORRETOR
  AVALIADOR
  DESIGNER_INTERIORES
  FOTOGRAFO
  VIDEOMAKER
  ADVOGADO_IMOBILIARIO
  DESPACHANTE
  OUTRO
}

enum SpecialistStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Specialist {
  id                 String             @id @default(cuid())
  slug               String             @unique
  name               String
  email              String             @unique
  phone              String?
  whatsapp           String?
  category           SpecialistCategory
  bio                String?            @db.Text
  city               String             @default("Franca")
  state              String             @default("SP")
  crea               String?
  instagram          String?
  website            String?
  photoUrl           String?
  status             SpecialistStatus   @default(PENDING)
  tags               String[]
  buildings          SpecialistBuilding[]
  welcomeEmailSentAt DateTime?

  // Pagamentos Asaas
  cpfCnpj            String?
  plan               SpecialistPlan     @default(START)
  planStatus         String?            @default("FREE")
  planActivatedAt    DateTime?
  planExpiresAt      DateTime?
  asaasCustomerId    String?
  asaasSubscriptionId String?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status])
  @@index([category])
  @@index([city, state])
  @@index([plan])
  @@map("specialists")
}

enum SpecialistPlan {
  START
  PRIME
  VIP
}

model Building {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  city         String   @default("Franca")
  state        String   @default("SP")
  neighborhood String?
  address      String?
  floors       Int?
  units        Int?
  yearBuilt    Int?
  description  String?  @db.Text
  specialists  SpecialistBuilding[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([city, state])
  @@index([neighborhood])
  @@map("buildings")
}

model SpecialistBuilding {
  id           String     @id @default(cuid())
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  specialistId String
  building     Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId   String
  projectType  String?
  year         Int?
  createdAt    DateTime   @default(now())

  @@unique([specialistId, buildingId])
  @@index([specialistId])
  @@index([buildingId])
  @@map("specialist_buildings")
}

// =============================================================================
// AI MARKETING & LEAD SCORING (Phase: Nexus Imobi)
// =============================================================================

/// Registro de interações do lead para alimentar o Lead Scoring
model LeadInteraction {
  id          String   @id @default(cuid())
  leadId      String?
  contactId   String?
  sessionId   String?      // Browser session ID
  eventType   String       // page_view | property_view | photo_view | whatsapp_click | phone_click | favorite | search | message
  propertyId  String?
  metadata    Json     @default("{}")  // { duration, source, utm_*, etc. }
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([contactId])
  @@index([sessionId])
  @@index([eventType])
  @@index([propertyId])
  @@index([createdAt])
  @@map("lead_interactions")
}

/// Configuração de régua de cobrança por empresa
model BillingRule {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  daysOffset  Int         // Negativo = antes, positivo = depois do vencimento
  channel     String      // whatsapp | email | sms | push
  templateKey String
  message     String?  @db.Text  // Template da mensagem (com placeholders)
  isActive    Boolean  @default(true)
  isAutomated Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([daysOffset])
  @@map("billing_rules")
}

/// Log de notificações de cobrança enviadas
model BillingNotification {
  id          String   @id @default(cuid())
  companyId   String
  rentalId    String
  contractId  String?
  ruleId      String?      // BillingRule.id
  channel     String       // whatsapp | email | sms
  templateKey String
  status      String   @default("SENT")  // SENT | DELIVERED | READ | FAILED
  message     String?  @db.Text
  errorMsg    String?
  sentAt      DateTime @default(now())

  @@index([companyId])
  @@index([rentalId])
  @@index([sentAt])
  @@map("billing_notifications")
}

/// Registro de repasses ao proprietário
model OwnerRepasse {
  id              String    @id @default(cuid())
  companyId       String
  contractId      String
  landlordId      String    // Client.id do proprietário
  rentalId        String?
  month           Int
  year            Int
  grossValue      Decimal   @db.Decimal(12, 2)  // Valor bruto recebido
  commissionValue Decimal   @db.Decimal(12, 2)  // Comissão da imobiliária
  adminFeeValue   Decimal?  @db.Decimal(12, 2)  // Taxa de administração
  netValue        Decimal   @db.Decimal(12, 2)  // Valor líquido para o proprietário
  status          String    @default("PENDING")  // PENDING | PAID | CANCELLED
  paidAt          DateTime?
  paymentMethod   String?   // PIX | TED | BOLETO | DINHEIRO
  paymentRef      String?   // Comprovante/referência
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([landlordId])
  @@index([contractId])
  @@index([month, year])
  @@index([status])
  @@map("owner_repasses")
}

/// Histórico de valorização de imóveis (para dashboard do proprietário)
model PropertyValuation {
  id          String   @id @default(cuid())
  propertyId  String
  valuatedAt  DateTime @default(now())
  value       Decimal  @db.Decimal(14, 2)   // Valor estimado
  source      String   @default("ai")       // ai | manual | market
  pricePerM2  Decimal? @db.Decimal(10, 2)
  methodology String?                        // CMA | Income | AI_Model
  notes       String?
  metadata    Json     @default("{}")        // Dados da avaliação

  @@index([propertyId])
  @@index([valuatedAt])
  @@map("property_valuations")
}

/// Posts de redes sociais gerados automaticamente
model SocialPost {
  id          String    @id @default(cuid())
  companyId   String
  propertyId  String?
  platform    String       // instagram | facebook | tiktok | linkedin
  caption     String    @db.Text
  hashtags    String?   @db.Text
  imageUrls   String[]
  postId      String?      // ID do post na rede social
  postUrl     String?
  status      String    @default("DRAFT")  // DRAFT | SCHEDULED | PUBLISHED | FAILED
  scheduledAt DateTime?
  publishedAt DateTime?
  errorMsg    String?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([propertyId])
  @@index([platform])
  @@index([status])
  @@map("social_posts")
}

// =============================================================================
// SAAS: MULTI-TENANT (Clones / Revenda de Sistemas)
// =============================================================================

/// Tenant = um clone/site parceiro vendido como SaaS
model Tenant {
  id                  String    @id @default(cuid())
  ownerId             String?   // User ID do proprietário do clone
  companyId           String?   // Company vinculada (se já existir)
  name                String    // Nome da empresa parceira
  subdomain           String    @unique  // ex: 'imobiliaria-joao'
  customDomain        String?   @unique  // ex: 'www.joaoimoveis.com.br'
  domainType          String    @default("subdomain") // subdomain | new | own
  layoutType          String    @default("clean")     // luxury | clean | social | marketplace
  primaryColor        String    @default("#3b82f6")
  logoUrl             String?
  faviconUrl          String?
  plan                String    @default("LITE")      // LITE | PRO | ENTERPRISE
  planStatus          String    @default("TRIAL")     // TRIAL | ACTIVE | PAST_DUE | SUSPENDED | CANCELLED
  planPrice           Decimal?  @db.Decimal(10, 2)
  splitPercent        Decimal   @default(2.00) @db.Decimal(5, 2) // % que fica com Agora Encontrei
  repasseDelayDays    Int       @default(7)           // D+7 padrão
  repasseFixedDay     Int?      // Dia fixo do mês (1-31) se preferir
  asaasApiKey         String?   // API key Asaas do parceiro
  asaasWalletId       String?   // Subconta Asaas para split
  asaasSubscriptionId String?   // ID da assinatura SaaS no Asaas
  vercelDomainId      String?   // ID do domínio na Vercel
  settings            Json      @default("{}")
  isActive            Boolean   @default(true)
  trialEndsAt         DateTime?
  activatedAt         DateTime?
  suspendedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([subdomain])
  @@index([customDomain])
  @@index([planStatus])
  @@index([ownerId])
  @@map("tenants")
}

/// Log de comissões/splits recebidos dos clones SaaS
model SaasCommissionLog {
  id              String    @id @default(cuid())
  tenantId        String
  transactionId   String?   // ID do repasse que originou
  originalValue   Decimal   @db.Decimal(14, 2) // Valor bruto da transação
  splitPercent    Decimal   @db.Decimal(5, 2)  // % de split aplicado
  commissionValue Decimal   @db.Decimal(14, 2) // Comissão da plataforma
  tenantNetValue  Decimal   @db.Decimal(14, 2) // Valor líquido do tenant
  status          String    @default("PENDING") // PENDING | COMPLETED | FAILED
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("saas_commission_logs")
}

/// Repasses agendados (custódia D+7 ou dia fixo)
model ScheduledRepasse {
  id              String    @id @default(cuid())
  tenantId        String?
  companyId       String
  contractId      String?
  rentalId        String?
  landlordId      String
  grossValue      Decimal   @db.Decimal(14, 2)
  commissionValue Decimal   @db.Decimal(14, 2) @default(0)
  netValue        Decimal   @db.Decimal(14, 2)
  scheduledDate   DateTime  // Data programada para liberação
  status          String    @default("SCHEDULED") // SCHEDULED | PROCESSING | COMPLETED | FAILED
  asaasTransferId String?
  processedAt     DateTime?
  failureReason   String?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([tenantId])
  @@index([landlordId])
  @@index([scheduledDate])
  @@index([status])
  @@map("scheduled_repasses")
}

/// Contratos de assinatura digital (Clicksign)
model DigitalSignature {
  id              String    @id @default(cuid())
  companyId       String
  contractId      String?
  documentType    String    @default("RENTAL") // RENTAL | SALE | PROPOSAL
  documentUrl     String?   // URL do PDF gerado
  externalId      String?   // ID no Clicksign
  envelopeUrl     String?   // Link para assinatura
  status          String    @default("PENDING") // PENDING | SENT | SIGNED | CANCELLED | EXPIRED
  signers         Json      @default("[]") // Array de signatários
  signedAt        DateTime?
  expiresAt       DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([externalId])
  @@index([status])
  @@map("digital_signatures")
}

/// Análises de leilão geradas por IA
model AuctionAIAnalysis {
  id              String   @id @default(cuid())
  auctionId       String
  editalUrl       String?
  debtIPTU        Decimal? @db.Decimal(12, 2)
  debtCondo       Decimal? @db.Decimal(12, 2)
  debtOther       Decimal? @db.Decimal(12, 2)
  isOccupied      Boolean?
  occupationType  String?  // OWNER | TENANT | SQUATTER | UNKNOWN
  leiloeirFee     Decimal? @db.Decimal(5, 2)  // % do leiloeiro
  itbiEstimate    Decimal? @db.Decimal(12, 2)
  escrituraEstimate Decimal? @db.Decimal(12, 2)
  reformEstimate  Decimal? @db.Decimal(12, 2)
  totalCost       Decimal? @db.Decimal(14, 2)  // Lance + todos os custos
  marketValue     Decimal? @db.Decimal(14, 2)  // Valor de mercado estimado
  roiPercent      Float?                        // ROI estimado
  paybackMonths   Int?                          // Meses para payback via aluguel
  yieldMonthly    Float?                        // Yield mensal estimado
  riskLevel       String?  // LOW | MEDIUM | HIGH
  aiSummary       String?  @db.Text             // Resumo IA do edital
  rawExtraction   Json     @default("{}")       // Dados brutos extraídos
  createdAt       DateTime @default(now())

  @@unique([auctionId])
  @@index([riskLevel])
  @@map("auction_ai_analyses")
}

// =============================================================================
// TOMÁS OS — AI Agent Conversacional
// =============================================================================

/// Conversas do agente Tomás (site público + dashboard interno)
model TomasChat {
  id            String    @id @default(cuid())
  companyId     String?
  leadId        String?
  contactId     String?
  userId        String?   // corretor/admin no modo interno
  channel       String    @default("site")  // "site" | "dashboard"
  visitorId     String?   // fingerprint anônimo para visitantes
  propertyId    String?   // contexto do imóvel (quando aberto na página)
  summary       String?   @db.Text
  nextAction    String?
  handoffNeeded Boolean   @default(false)
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      TomasChatMessage[]

  @@index([companyId])
  @@index([leadId])
  @@index([visitorId])
  @@index([channel])
  @@map("tomas_chats")
}

/// Mensagens individuais do chat do Tomás
model TomasChatMessage {
  id            String    @id @default(cuid())
  chatId        String
  chat          TomasChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role          String    // "user" | "assistant" | "system" | "tool"
  content       String    @db.Text
  toolName      String?
  toolPayload   Json?
  audioUrl      String?
  actions       Json?     // ações sugeridas pelo Tomás
  createdAt     DateTime  @default(now())

  @@index([chatId])
  @@map("tomas_chat_messages")
}

// =============================================================================
// TOUR VIRTUAL
// =============================================================================

/// Tours virtuais vinculados a imóveis
model PropertyTour {
  id               String   @id @default(cuid())
  companyId        String
  propertyId       String
  tourType         String   @default("essential") // "essential" | "video_guided" | "tour_360"
  provider         String   @default("internal")  // "internal" | "matterport" | "custom"
  embedUrl         String?
  processingStatus String   @default("queued")     // "queued" | "processing" | "ready" | "failed"
  qualityScore     Float?
  roomCount        Int?
  metadata         Json     @default("{}")
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@index([propertyId])
  @@index([processingStatus])
  @@map("property_tours")
}

// =============================================================================
// PROPOSTA DIGITAL — Deal Flow
// =============================================================================

/// Propostas digitais de compra/aluguel
model Proposal {
  id             String   @id @default(cuid())
  companyId      String
  propertyId     String
  leadId         String?
  contactId      String?
  offerValue     Decimal  @db.Decimal(14, 2)
  paymentMethod  String?  // "cash" | "finance" | "installments" | "exchange"
  downPayment    Decimal? @db.Decimal(14, 2)
  financingAmount Decimal? @db.Decimal(14, 2)
  status         String   @default("sent") // "draft" | "sent" | "countered" | "accepted" | "rejected" | "expired"
  notes          String?  @db.Text
  expiresAt      DateTime?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  events         ProposalEvent[]

  @@index([companyId])
  @@index([propertyId])
  @@index([leadId])
  @@index([status])
  @@map("proposals")
}

/// Eventos de negociação da proposta
model ProposalEvent {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  type        String   // "created" | "sent" | "countered" | "accepted" | "rejected" | "expired"
  note        String?  @db.Text
  value       Decimal? @db.Decimal(14, 2)
  actorType   String?  // "buyer" | "seller" | "broker" | "system"
  createdAt   DateTime @default(now())

  @@index([proposalId])
  @@map("proposal_events")
}

// =============================================================================
// SEGURANÇA — Controle de Acesso Sensível (LGPD)
// =============================================================================

/// Grant temporário para visualizar dados sensíveis (telefone, CPF, email completo)
model SensitiveAccessGrant {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  entityType  String   // "lead" | "contact"
  entityId    String
  reason      String   // "atendimento" | "proposta" | "visita" | "contrato"
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId, entityType, entityId])
  @@index([expiresAt])
  @@map("sensitive_access_grants")
}

// =============================================================================
// DYNAMIC ADMIN CONTROL — "The Master Toggle"
// Configuração dinâmica: preços, nichos, módulos e settings editáveis via admin
// =============================================================================

/// Definição de plano — preços, limites e features editáveis sem deploy
model PlanDefinition {
  id               String    @id @default(cuid())
  slug             String    @unique             // "lite", "pro", "enterprise", "cartao_visita"
  name             String                        // Nome de exibição: "Lite", "Pro"
  description      String?   @db.Text            // Descrição curta
  longDescription  String?   @db.Text            // Descrição longa (landing page)
  priceMonthly     Decimal   @db.Decimal(10, 2)  // Preço mensal
  priceYearly      Decimal?  @db.Decimal(10, 2)  // Preço anual (desconto)
  maxProperties    Int       @default(-1)        // -1 = ilimitado
  maxLeadViews     Int       @default(-1)
  maxUsers         Int       @default(1)
  maxAIRequests    Int       @default(0)         // Requisições IA/mês
  themes           String[]  @default([])        // Themes permitidos (slug): ["urban_tech","classic_trust"] ou ["all"]
  modules          String[]  @default([])        // Módulos inclusos (slug): ["site_basico","crm","ia_tomas"]
  features         String[]  @default([])        // Lista de features para exibição: ["Até 5 imóveis", "CRM básico"]
  nicheFilter      String[]  @default([])        // Se não-vazio, plano só aparece p/ esses nichos
  billingType      String    @default("recurring") // "recurring" | "one_time"
  highlighted      Boolean   @default(false)     // Badge "Mais popular"
  sortOrder        Int       @default(0)
  isActive         Boolean   @default(true)
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isActive, sortOrder])
  @@map("plan_definitions")
}

/// Template de nicho — define como o Tomás se comporta, labels, campos de busca
model NicheTemplate {
  id                   String    @id @default(cuid())
  slug                 String    @unique           // "imobiliaria", "estetica", "advocacia", "moveis"
  name                 String                      // "Imobiliária", "Estética e Beleza"
  icon                 String?                     // Lucide icon name: "building-2", "sparkles"
  description          String?   @db.Text
  tomasPersona         String    @db.Text          // Instrução de persona do Tomás para este nicho
  tomasGreeting        String?   @db.Text          // Saudação personalizada
  tomasTone            String    @default("consultivo") // "formal" | "agil" | "acolhedor" | "consultivo" | "direto"
  itemLabel            String    @default("Imóvel")     // O que o nicho vende: "Imóvel", "Veículo", "Serviço"
  itemLabelPlural      String    @default("Imóveis")
  searchFields         Json      @default("[]")    // Campos de busca customizados: [{key:"quartos",label:"Quartos"},{key:"ano",label:"Ano/Modelo"}]
  categoryFields       Json      @default("[]")    // Categorias de filtro: ["Residencial","Comercial"] ou ["Sedã","SUV","Pickup"]
  seoKeywords          String[]  @default([])      // Palavras-chave globais p/ SEO programático
  seoTitleTemplate     String?                     // "Melhor {item} em {cidade} - {partner}"
  defaultTheme         String    @default("urban_tech")
  availableThemes      String[]  @default([])      // Themes específicos para este nicho
  sortOrder            Int       @default(0)
  isActive             Boolean   @default(true)
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([isActive, sortOrder])
  @@map("niche_templates")
}

/// Módulo avulso — recursos ativáveis por tenant (add-ons)
model ModuleDefinition {
  id               String    @id @default(cuid())
  slug             String    @unique             // "ia_tomas_voz", "crm_avancado", "blog_seo"
  name             String                        // "IA Tomás com Voz"
  description      String?   @db.Text
  priceMonthly     Decimal?  @db.Decimal(10, 2)  // null = incluso em plano
  priceOneTime     Decimal?  @db.Decimal(10, 2)  // Taxa única (se aplicável)
  billingType      String    @default("recurring") // "recurring" | "one_time" | "included"
  category         String    @default("feature")   // "feature" | "integration" | "ai" | "design"
  requiredPlan     String?                       // Plano mínimo: "pro" (null = qualquer)
  nicheFilter      String[]  @default([])        // Se não-vazio, módulo só aparece p/ esses nichos
  icon             String?                       // Lucide icon name
  sortOrder        Int       @default(0)
  isActive         Boolean   @default(true)
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  activations      TenantModuleActivation[]

  @@index([isActive, sortOrder])
  @@map("module_definitions")
}

/// Serviço avulso — operacional/humano (implantação, mentoria, setup)
model ServiceDefinition {
  id               String    @id @default(cuid())
  slug             String    @unique             // "implantacao_vip", "mentoria_estrategica"
  name             String                        // "Implantação VIP"
  description      String?   @db.Text
  longDescription  String?   @db.Text
  price            Decimal   @db.Decimal(10, 2)
  billingType      String    @default("one_time")  // "one_time" | "recurring"
  category         String    @default("service")   // "service" | "consulting" | "premium"
  nicheFilter      String[]  @default([])
  icon             String?
  sortOrder        Int       @default(0)
  isActive         Boolean   @default(true)
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orders           TenantServiceOrder[]

  @@index([isActive, sortOrder])
  @@map("service_definitions")
}

/// Ativação de módulo por tenant
model TenantModuleActivation {
  id             String    @id @default(cuid())
  tenantId       String
  moduleId       String
  status         String    @default("active")    // "active" | "suspended" | "cancelled" | "pending_payment"
  activatedAt    DateTime  @default(now())
  expiresAt      DateTime?
  cancelledAt    DateTime?
  asaasChargeId  String?                         // ID da cobrança no Asaas
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  module         ModuleDefinition @relation(fields: [moduleId], references: [id])

  @@unique([tenantId, moduleId])
  @@index([tenantId, status])
  @@map("tenant_module_activations")
}

/// Pedido de serviço por tenant
model TenantServiceOrder {
  id             String    @id @default(cuid())
  tenantId       String
  serviceId      String
  status         String    @default("pending")   // "pending" | "paid" | "in_progress" | "completed" | "cancelled"
  paidAt         DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  asaasChargeId  String?
  notes          String?   @db.Text
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  service        ServiceDefinition @relation(fields: [serviceId], references: [id])

  @@index([tenantId, status])
  @@map("tenant_service_orders")
}

/// Configurações globais do sistema — singleton editável via admin
model GlobalSystemSettings {
  id             String    @id @default("global")
  seoDefaults    Json      @default("{}")      // { titleTemplate, descriptionTemplate, keywords[] }
  landingContent Json      @default("{}")      // { headline, subtitle, faq[], testimonials[] }
  billingConfig  Json      @default("{}")      // { asaasMode, defaultSplit, trialDays }
  featureFlags   Json      @default("{}")      // { enableHunterMode, enableVoiceAI, enableBlog }
  brandConfig    Json      @default("{}")      // { platformName, primaryColor, logoUrl }
  metadata       Json      @default("{}")
  updatedAt      DateTime  @updatedAt
  updatedBy      String?                       // userId que fez última edição

  @@map("global_system_settings")
}

/// Configuração por chave — tabela genérica para settings platform-level
model SystemConfig {
  id         String   @id @default(cuid())
  companyId  String   @default("platform")
  key        String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, key])
  @@map("system_configs")
}

// =============================================================================
// HUNTER MODE — Leads de busca difícil (leilões, portais privados)
// =============================================================================

/// Lead criado quando visitante busca 2x sem resultado e aceita ser avisado
model HunterLead {
  id          String    @id @default(cuid())
  leadId      String?   // FK para Lead (se já convertido)
  contactId   String?   // FK para Contact (se identificado)
  visitorId   String?   // fingerprint anônimo do visitante
  name        String?
  phone       String?
  email       String?
  filters     Json      @default("{}")  // { city, neighborhood, priceMin, priceMax, type, bedrooms, intent }
  status      String    @default("active")  // active | fulfilled | expired | contacted
  priority    String    @default("URGENTE_HUNTER")
  source      String    @default("site_search")  // site_search | tomas_chat | whatsapp
  notes       String?
  fulfilledAt DateTime?
  expiredAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([leadId])
  @@index([createdAt])
  @@map("hunter_leads")
}

// =============================================================================
// AFFILIATE ENGINE — Sistema de afiliados para escala
// =============================================================================

/// Afiliado que indica clientes para a plataforma
model Affiliate {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  phone           String?
  code            String    @unique  // Código único de indicação (ex: JOAO123)
  commissionRate  Decimal   @default(0.20) @db.Decimal(5, 4)  // 0.20 = 20%
  level           String    @default("bronze")  // bronze | prata | ouro
  totalEarnings   Decimal   @default(0) @db.Decimal(12, 2)
  pendingEarnings Decimal   @default(0) @db.Decimal(12, 2)
  totalClients    Int       @default(0)
  isActive        Boolean   @default(true)
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  earnings        AffiliateEarning[]
  referrals       AffiliateReferral[]

  @@index([code])
  @@index([email])
  @@index([isActive])
  @@map("affiliates")
}

/// Registro de ganho do afiliado por cada pagamento confirmado
model AffiliateEarning {
  id              String    @id @default(cuid())
  affiliateId     String
  affiliate       Affiliate @relation(fields: [affiliateId], references: [id])
  tenantId        String?   // Tenant indicado pelo afiliado
  transactionId   String?   // Referência à transação SaaS
  amount          Decimal   @db.Decimal(12, 2)  // Valor da comissão
  grossValue      Decimal   @db.Decimal(12, 2)  // Valor bruto do pagamento
  status          String    @default("pending")  // pending | paid | cancelled
  paidAt          DateTime?
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([affiliateId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("affiliate_earnings")
}

// =============================================================================
// SAAS FINANCIAL — Transações financeiras da plataforma SaaS
// =============================================================================

/// Transação financeira SaaS (assinatura tenant, módulo, serviço, comissão afiliado)
model SaasFinancialTransaction {
  id              String    @id @default(cuid())
  tenantId        String?
  affiliateId     String?
  asaasId         String?   // ID do pagamento no Asaas
  type            String    // subscription | module | service | commission | refund
  status          String    @default("pending")  // pending | paid | overdue | cancelled | refunded
  amount          Decimal   @db.Decimal(12, 2)   // Valor bruto
  netAmount       Decimal?  @db.Decimal(12, 2)   // Valor líquido (após comissão afiliado)
  commissionAmount Decimal? @db.Decimal(12, 2)   // Comissão do afiliado
  dueDate         DateTime?
  paidAt          DateTime?
  description     String?
  externalRef     String?   // Referência externa (externalReference do Asaas)
  billingType     String?   // PIX | BOLETO | CREDIT_CARD
  pixCode         String?   // PIX Copia e Cola
  bankSlipUrl     String?   // URL do boleto
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([affiliateId])
  @@index([asaasId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("saas_financial_transactions")
}

/// Rastreio de indicação de afiliado — tracking, conversão, vínculo com tenant
model AffiliateReferral {
  id            String    @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id])
  tenantId      String?   // Preenchido quando lead converte em tenant
  leadId        String?   // Lead associado à indicação
  referralCode  String    // Código usado na indicação
  source        String    @default("link")  // link | checkout | whatsapp | manual
  status        String    @default("tracked")  // tracked | converted | cancelled
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([affiliateId])
  @@index([tenantId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@map("affiliate_referrals")
}

/// Preview session — site temporário para demonstração comercial
model PreviewSession {
  id           String    @id @default(cuid())
  siteName     String    // slug do preview (ex: joao-imoveis)
  companyName  String    // Nome da empresa/corretor
  theme        String    @default("urban_tech")
  slogan       String?
  segment      String    @default("corretor")  // corretor | imobiliaria | loteadora | construtora
  city         String?
  logoUrl      String?
  previewToken String    @unique  // Token seguro para acesso
  expiresAt    DateTime  // Expiração (default 72h)
  viewCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([siteName])
  @@index([previewToken])
  @@index([expiresAt])
  @@map("preview_sessions")
}

/// Mensagem outbound enviada — tracking de disparo, A/B, taxa de resposta
model OutboundMessage {
  id              String    @id @default(cuid())
  leadId          String?
  phone           String    // Telefone destino
  senderNumber    String    // Número remetente (rotação)
  templateVersion String    @default("A") // A | B | C — para A/B testing
  campaignId      String?   // Identificador de campanha
  channel         String    @default("whatsapp") // whatsapp | sms | email
  message         String    @db.Text // Conteúdo enviado
  previewLink     String?   // Link de preview se incluído
  status          String    @default("queued") // queued | sent | delivered | read | replied | failed
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  repliedAt       DateTime?
  errorMessage    String?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([leadId])
  @@index([phone])
  @@index([senderNumber])
  @@index([campaignId])
  @@index([status])
  @@index([templateVersion])
  @@index([createdAt])
  @@map("outbound_messages")
}

/// Follow-up agendado — D+1, D+3, D+7 automáticos para leads
model FollowUpSchedule {
  id              String    @id @default(cuid())
  leadId          String
  outboundId      String?   // OutboundMessage original que gerou o follow-up
  phone           String
  step            String    // d1 | d3 | d7
  scheduledAt     DateTime  // Quando disparar
  templateVersion String    @default("A")
  status          String    @default("pending") // pending | sent | skipped | cancelled
  sentAt          DateTime?
  skipReason      String?   // "replied" | "converted" | "unsubscribed"
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([scheduledAt])
  @@index([step])
  @@map("followup_schedules")
}

/// Funil de vendas SaaS — tracking de conversão do lead ao cliente
model SalesFunnel {
  id              String    @id @default(cuid())
  leadId          String?
  phone           String?
  email           String?
  name            String?
  source          String    // whatsapp_outbound | meta_ads | google_ads | seo | affiliate | organic
  campaign        String?
  affiliateCode   String?
  stage           String    @default("captured") // captured | engaged | preview_sent | preview_clicked | checkout_sent | converted | lost
  previewSiteName String?   // preview gerado para este lead
  checkoutUrl     String?   // link de checkout gerado
  convertedAt     DateTime?
  tenantId        String?   // Tenant criado após conversão
  score           Int       @default(0)
  tags            String[]
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([phone])
  @@index([email])
  @@index([source])
  @@index([stage])
  @@index([campaign])
  @@index([affiliateCode])
  @@index([createdAt])
  @@map("sales_funnels")
}
