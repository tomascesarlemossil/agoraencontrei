  companyId   String
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  action      String   // REAJUSTE | RENOVACAO | RESCISAO | ALTERACAO | CRIACAO
  description String?  @db.Text
  field       String?  // campo alterado
