// =============================================================================
// AgoraEncontrei + Lemosbank — Prisma Schema
// Fase 1: Infraestrutura Base
// PostgreSQL (Neon)
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  BROKER
  FINANCIAL
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  SUSPENDED
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  FARM
  RANCH
  WAREHOUSE
  OFFICE
  STORE
  STUDIO
  PENTHOUSE
  CONDO
  KITNET
}

enum PropertyPurpose {
  SALE
  RENT
  BOTH
  SEASON
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  SOLD
  RENTED
  PENDING
  DRAFT
}

enum PropertyCategory {
  RESIDENTIAL
  COMMERCIAL
  RURAL
  INDUSTRIAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VISITING
  PROPOSAL
  NEGOTIATING
  WON
  LOST
  ARCHIVED
}

enum DealStatus {
  OPEN
  IN_PROGRESS
  PROPOSAL
  CONTRACT
  CLOSED_WON
  CLOSED_LOST
}

enum NegotiationType {
  SALE
  RENT
}

enum ContactType {
  INDIVIDUAL
  COMPANY
}

// =============================================================================
// CORE: COMPANY (Imobiliária)
// =============================================================================

model Company {
  id        String   @id @default(cuid())
  name      String
  tradeName String?
  cnpj      String?  @unique
  creci     String?
  phone     String?
  email     String?
  website   String?
  logoUrl   String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  plan      String   @default("starter")
  settings  Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  properties Property[]
  contacts   Contact[]
  leads      Lead[]
  deals      Deal[]
  portals    PortalConfig[]

  @@map("companies")
}

// =============================================================================
// AUTH: USERS + SESSIONS
// =============================================================================

model User {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id])
  name            String
  email           String     @unique
  phone           String?
  passwordHash    String?
  avatarUrl       String?
  role            UserRole   @default(BROKER)
  status          UserStatus @default(PENDING_VERIFICATION)
  creciNumber     String?
  bio             String?
  settings        Json       @default("{}")
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sessions      Session[]
  oauthAccounts OAuthAccount[]
  properties    Property[]
  leads         Lead[]         @relation("BrokerLeads")
  assignedLeads Lead[]         @relation("AssignedLeads")
  deals         Deal[]
  activities    Activity[]
  refreshTokens RefreshToken[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @default(cuid())
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  family    String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model OAuthAccount {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String // "google" | "facebook"
  providerUserId String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model EmailVerification {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("password_resets")
}

// =============================================================================
// CONTACTS (Clientes, Proprietários, Inquilinos)
// =============================================================================

model Contact {
  id           String      @id @default(cuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  type         ContactType @default(INDIVIDUAL)
  name         String
  email        String?
  phone        String?
  mobilePhone  String?
  cpf          String?
  cnpj         String?
  rg           String?
  birthDate    DateTime?
  address      String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  notes        String?
  tags         String[]
  isOwner      Boolean     @default(false)
  isTenant     Boolean     @default(false)
  isGuarantor  Boolean     @default(false)
  externalId   String? // Uniloc CODINQ / CODLOC
  source       String? // "uniloc", "manual", "portal", "whatsapp"
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  leads           Lead[]
  deals           Deal[]
  activities      Activity[]
  ownedProperties PropertyOwner[]

  @@index([companyId])
  @@index([email])
  @@index([cpf])
  @@index([externalId])
  @@map("contacts")
}

// =============================================================================
// PROPERTIES
// =============================================================================

model Property {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  reference   String? // ex: LEM-0087
  externalId  String? // Univen ID Internet
  title       String
  slug        String
  description String?
  type        PropertyType     @default(HOUSE)
  purpose     PropertyPurpose  @default(SALE)
  category    PropertyCategory @default(RESIDENTIAL)
  status      PropertyStatus   @default(ACTIVE)

  // Pricing
  price           Decimal? @db.Decimal(12, 2)
  priceRent       Decimal? @db.Decimal(12, 2)
  priceSeason     Decimal? @db.Decimal(12, 2)
  priceNegotiable Boolean  @default(false)
  condoFee        Decimal? @db.Decimal(10, 2)
  iptu            Decimal? @db.Decimal(10, 2)

  // Location
  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  country      String  @default("BR")
  latitude     Float?
  longitude    Float?
  showAddress  Boolean @default(true)
  condoName    String?

  // Characteristics
  totalArea     Float?
  builtArea     Float?
  landArea      Float?
  bedrooms      Int    @default(0)
  suites        Int    @default(0)
  bathrooms     Int    @default(0)
  parkingSpaces Int    @default(0)
  floor         Int?
  totalFloors   Int?
  yearBuilt     Int?

  // Media
  coverImage     String?
  images         String[]
  videoUrl       String?
  virtualTourUrl String?

  // Features & amenities
  features String[] // ["pool", "gym", "barbecue", ...]

  // SEO
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]

  // Portal descriptions (per portal AI-generated)
  portalDescriptions Json @default("{}")

  // Analytics
  views     Int @default(0)
  favorites Int @default(0)
  leads     Int @default(0)

  // Flags
  isFeatured    Boolean   @default(false)
  isPremium     Boolean   @default(false)
  isHighlighted Boolean   @default(false)
  featuredUntil DateTime?

  // Import metadata
  importSource String? // "univen_xls", "manual", "portal_xml"
  importedAt   DateTime?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owners             PropertyOwner[]
  portalPublications PortalPublication[]
  dealProperties     DealProperty[]
  leadProperties     LeadProperty[]
  activities         Activity[]

  @@unique([companyId, slug])
  @@unique([companyId, reference])
  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([type, purpose])
  @@index([city, neighborhood])
  @@index([externalId])
  @@map("properties")
}

model PropertyOwner {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id])
  percentage Decimal  @default(100) @db.Decimal(5, 2)
  createdAt  DateTime @default(now())

  @@unique([propertyId, contactId])
  @@map("property_owners")
}

// =============================================================================
// PORTALS
// =============================================================================

model PortalConfig {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  portalId   String // "olx", "zap", "vivareal", "facebook", ...
  portalName String
  apiKey     String?
  apiSecret  String?
  settings   Json      @default("{}")
  isActive   Boolean   @default(false)
  isPaid     Boolean   @default(false)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([companyId, portalId])
  @@map("portal_configs")
}

model PortalPublication {
  id          String    @id @default(cuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  portalId    String
  externalId  String?
  status      String    @default("pending") // pending, published, failed, removed
  publishedAt DateTime?
  errorMsg    String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([propertyId, portalId])
  @@map("portal_publications")
}

// =============================================================================
// CRM: LEADS + DEALS
// =============================================================================

model Lead {
  id            String     @id @default(cuid())
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id])
  contactId     String?
  contact       Contact?   @relation(fields: [contactId], references: [id])
  brokerId      String? // who captured
  broker        User?      @relation("BrokerLeads", fields: [brokerId], references: [id])
  assignedToId  String? // who is responsible now
  assignedTo    User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  name          String
  email         String?
  phone         String?
  status        LeadStatus @default(NEW)
  source        String? // "whatsapp", "portal", "site", "referral", "manual"
  interest      String? // "buy", "rent"
  budget        Decimal?   @db.Decimal(12, 2)
  notes         String?
  score         Int        @default(0)
  tags          String[]
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  metadata      Json       @default("{}")
  lastContactAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  properties LeadProperty[]
  deals      Deal[]
  activities Activity[]

  @@index([companyId])
  @@index([brokerId])
  @@index([assignedToId])
  @@index([status])
  @@map("leads")
}

model LeadProperty {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([leadId, propertyId])
  @@map("lead_properties")
}

model Deal {
  id              String          @id @default(cuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  leadId          String?
  lead            Lead?           @relation(fields: [leadId], references: [id])
  brokerId        String
  broker          User            @relation(fields: [brokerId], references: [id])
  contactId       String?
  contact         Contact?        @relation(fields: [contactId], references: [id])
  title           String
  type            NegotiationType @default(SALE)
  status          DealStatus      @default(OPEN)
  value           Decimal?        @db.Decimal(12, 2)
  commission      Decimal?        @db.Decimal(5, 2)
  notes           String?
  closedAt        DateTime?
  expectedCloseAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  properties DealProperty[]
  activities Activity[]

  @@index([companyId])
  @@index([brokerId])
  @@index([status])
  @@map("deals")
}

model DealProperty {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([dealId, propertyId])
  @@map("deal_properties")
}

// =============================================================================
// ACTIVITIES (Timeline unificado)
// =============================================================================

model Activity {
  id          String    @id @default(cuid())
  companyId   String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id])
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id])
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
  type        String // "note", "call", "email", "visit", "whatsapp", "status_change", "system"
  title       String
  description String?
  metadata    Json      @default("{}")
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([contactId])
  @@index([leadId])
  @@index([dealId])
  @@index([propertyId])
  @@map("activities")
}

// =============================================================================
// SYSTEM: API KEYS + AUDIT LOG
// =============================================================================

model ApiKey {
  id         String    @id @default(cuid())
  companyId  String
  userId     String
  name       String
  keyHash    String    @unique
  prefix     String // first 8 chars for display
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@index([companyId])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?
  userId     String?
  action     String // "user.login", "property.create", "deal.close", ...
  resource   String?
  resourceId String?
  ipAddress  String?
  userAgent  String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
